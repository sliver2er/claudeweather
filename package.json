{
  "name": "claudeweather",
  "version": "0.1.0",
  "description": "Weather backdrop renderer for Claude Code-style terminal welcome screens.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "claudeweather": "./src/cli.js"
  },
  "scripts": {
    "start": "node ./src/cli.js",
    "test": "node --test"
  },
  "files": [
    "src",
    "README.md",
    "README-ko.md",
    "LICENSE"
  ],
  "keywords": [
    "weather",
    "terminal",
    "claude-code",
    "welcome-screen",
    "cli",
    "developer-tools",
    "dashboard",
    "tui",
    "json"
  ],
  "author": "Wooseunghyun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sliver2er/claudeweather.git"
  },
  "bugs": {
    "url": "https://github.com/sliver2er/claudeweather/issues"
  },
  "homepage": "https://github.com/sliver2er/claudeweather#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.27.0"
}
